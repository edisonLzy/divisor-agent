# Renderer 进程请求的服务端地址 (见 src/renderer/lib/request.ts)
#
# Vite 会按 mode 自动加载:
#   - pnpm dev  → .env / .env.local / .env.development / .env.development.local
#   - pnpm build → .env / .env.local / .env.production  / .env.production.local
#
# 团队共享的 .env.<mode> 已提交仓库;如需个人本地覆盖(不提交),
# 请使用 .env.local 或 .env.<mode>.local。
VITE_SERVER_URL=http://localhost:3000
