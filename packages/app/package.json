{
  "name": "@divisor-agent/app",
  "version": "1.0.0",
  "description": "Electrobun desktop client for divisor-agent",
  "private": true,
  "scripts": {
    "start": "vite build && electrobun dev",
    "dev": "electrobun dev --watch",
    "dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
    "hmr": "vite --port 1420",
    "build": "vite build",
    "build:canary": "vite build && electrobun build --env=canary"
  },
  "dependencies": {
    "@divisor-agent/server": "workspace:*",
    "@tanstack/react-query": "^5.91.3",
    "@trpc/client": "^11.13.4",
    "@trpc/react-query": "^11.13.4",
    "electrobun": "1.16.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "catalog:",
    "vite": "^8.0.9"
  }
}
