{
	"name": "electrobun-react-tailwind-vite",
	"version": "1.0.0",
	"description": "Electrobun app with React, Tailwind CSS, and Vite HMR",
	"scripts": {
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --port 5173",
		"build:canary": "vite build && electrobun build --env=canary",
		"type-check": "tsc --noEmit"
	},
	"dependencies": {
		"@base-ui/react": "^1.4.1",
		"@fontsource-variable/geist": "^5.2.8",
		"@streamdown/cjk": "^1.0.3",
		"@streamdown/code": "^1.1.1",
		"@streamdown/math": "^1.0.2",
		"@streamdown/mermaid": "^1.0.2",
		"@tailwindcss/postcss": "^4.2.2",
		"ai": "^6.0.168",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"electrobun": "1.16.0",
		"lucide-react": "^1.8.0",
		"nanoid": "^5.1.9",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"shadcn": "^4.4.0",
		"streamdown": "^2.5.0",
		"tailwind-merge": "^3.5.0",
		"tw-animate-css": "^1.4.0",
		"zustand": "^5.0.12"
	},
	"devDependencies": {
		"@types/bun": "latest",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"autoprefixer": "^10.5.0",
		"concurrently": "^9.2.1",
		"postcss": "^8.5.10",
		"tailwindcss": "^4.2.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.9"
	}
}
