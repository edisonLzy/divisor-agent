{
  "name": "@divisor-agent/server",
  "version": "1.0.0",
  "description": "Express + TypeScript server for divisor-agent",
  "type": "module",
  "exports": {
    "./router": {
      "types": "./src/expose.ts"
    }
  },
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "type-check": "tsc --noEmit",
    "test": "vitest"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "@trpc/server": "^11.13.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.0.1",
    "pino": "^9.6.0",
    "pino-http": "^10.4.0",
    "superjson": "^2.2.6",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
